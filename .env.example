# Copy to `.env` for local development. `.env` is gitignored.
# In production, supply these as real environment variables instead.

# Discord bot token (required).
HONEYPOT_BOT_TOKEN=

# Path to the guild configuration file (optional, defaults to config/config.toml).
# HONEYPOT_CONFIG_PATH=config/config.toml

# Log filter (optional, defaults to `honeypot=info`).
# RUST_LOG=honeypot=debug

# Dry-run mode (optional, off by default). When set to `1` or `true`, bans and
# unbans are simulated: detection, log embeds, and buttons all run, but no member
# is actually banned or unbanned. Lets you debug the full flow on your own account
# without a throwaway account.
# HONEYPOT_DRY_RUN=1
