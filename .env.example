# Copy to `.env` for local development. `.env` is gitignored.
# In production, supply these as real environment variables instead.

# Discord bot token (required).
HONEYPOT_BOT_TOKEN=

# Path to the guild configuration file (optional, defaults to config/config.toml).
# HONEYPOT_CONFIG_PATH=config/config.toml

# Log filter (optional, defaults to `honeypot=info`).
# RUST_LOG=honeypot=debug

# Dry-run mode (optional, off by default). When set to `1` or `true`, bans and
# unbans are simulated: detection, log embeds, and buttons all run, but no member
# is actually banned or unbanned. Lets you debug the full flow on your own account
# without a throwaway account.
# HONEYPOT_DRY_RUN=1

# Preview mode channel (only read in builds with `--features preview`). When set,
# `cargo run --features preview` posts one of every log embed to this channel with
# sample data, then exits — no gateway connection, no config. Lets you review the
# embed layouts (e.g. on mobile) without tripping a real honeypot.
# HONEYPOT_PREVIEW_CHANNEL=123456789012345678

# Slash-command registration scope (optional, defaults to `global`). Set to
# `guild` to register commands only to the guilds in your config; guild commands
# propagate instantly, which is convenient in development. `global` (the
# production default) registers across every guild the bot is in, but Discord can
# take up to an hour to propagate.
# HONEYPOT_COMMAND_SCOPE=guild
